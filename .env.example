# Helmsman environment variables
# Copy this file to .env and adjust values for your setup.
# The gateway reads these at startup via os.LookupEnv.

# Address the gateway listens on
HELMSMAN_ADDR=:8080

# Comma-separated list of Ollama backend URLs
HELMSMAN_BACKEND_URLS=http://localhost:11434

# Redis address for rate limiting and semantic cache
HELMSMAN_REDIS_ADDR=localhost:6379

# Ollama base URL used for generating embeddings (nomic-embed-text)
HELMSMAN_EMBED_URL=http://localhost:11434
